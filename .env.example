APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
WEB_PORT=3000
DATABASE_URL=postgresql+psycopg://papertrace:papertrace@127.0.0.1:5432/papertrace
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CELERY_TASK_ALWAYS_EAGER=false
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
LOCAL_CACHE_DIR=.cache
LOCAL_DATA_DIR=.local
ENABLE_LIVE_BY_DEFAULT=true
ENABLE_LIVE_PAPER_FETCH=false
ARXIV_API_BASE_URL=https://export.arxiv.org
ARXIV_TIMEOUT_SECONDS=15
ARXIV_SOURCE_MAX_BYTES=8000000
PDF_FETCH_TIMEOUT_SECONDS=20
PDF_MAX_PAGES=12
PAPER_UPLOAD_MAX_BYTES=15000000
ENABLE_LIVE_REPO_TRACE=false
ENABLE_LIVE_REPO_ANALYSIS=false
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_TIMEOUT_SECONDS=15
REPO_CLONE_TIMEOUT_SECONDS=45
REPO_MAX_FILE_SIZE_BYTES=200000
REPO_MAX_FILES=200
REPO_ANALYSIS_EXCLUDE_DIRS=["docs","doc","examples","notebooks","assets",".github"]
REPO_ANALYSIS_EXCLUDE_FILENAMES=["readme.md","license","pnpm-lock.yaml","package-lock.json","yarn.lock","poetry.lock","uv.lock"]
REPO_ANALYSIS_INCLUDE_DIRS=["src","papertrace","trl","peft","flash_attn","flash_attn_interface","csrc","transformers","lora"]
GITHUB_TOKEN=
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30
LLM_PAPER_PARSE_MAX_SECTIONS=8
LLM_PAPER_PARSE_SECTION_CHARS=3500
LLM_PAPER_PARSE_TOTAL_CHARS=14000
LLM_PAPER_PARSE_MAX_BATCHES=3
